# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
JWT_SECRET=              # Required: A strong random string for signing session tokens
SUPABASE_URL=            # Required: Your Supabase Project URL
SUPABASE_ANON_KEY=       # Required: Your Supabase Anon/Public Key
VITE_SUPABASE_URL=       # Required: Frontend Supabase URL
VITE_SUPABASE_ANON_KEY=  # Required: Frontend Supabase Anon Key
GROQ_API_KEY=           # Optional: For AI-powered reports

# Note: This application is configured as a standalone persistent server.
# To deploy on traditional hosting (Render, Railway, VPS), run: npm start
