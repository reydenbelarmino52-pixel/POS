{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "/api/server.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/server.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
